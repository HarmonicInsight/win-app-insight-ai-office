<Window x:Class="InsightAiOffice.App.Views.TutorialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="チュートリアル — すぐに試せるサンプル"
        Width="680" Height="520" MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BgPrimaryBrush}"
        FontFamily="Yu Gothic UI, Meiryo, Segoe UI">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="チュートリアル" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock Text="クリックするだけで、サンプルデータとプロンプトが自動セットされます。そのまま送信してAIの動作を確認できます。"
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,4,0,0" />
        </StackPanel>

        <!-- チュートリアル一覧 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TutorialList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6" Padding="12,10" CornerRadius="6"
                                Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Cursor="Hand"
                                MouseLeftButtonUp="TutorialCard_Click"
                                Tag="{Binding Id}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="24"
                                           VerticalAlignment="Center" Margin="0,0,12,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding DepartmentTag}" FontSize="10"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
