<Window x:Class="InsightAiOffice.App.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Resources/InsightAiOffice.ico"
        Title="Insight AI Office - ヘルプ"
        Width="1050" Height="740"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPrimaryBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TOC Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="16,14,16,10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="目次" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                </Border>
                <ListBox x:Name="NavList" Grid.Row="1"
                         SelectionChanged="OnNavSelectionChanged"
                         Background="Transparent" BorderThickness="0"
                         Padding="4,6"/>
            </Grid>
        </Border>

        <!-- Content Area -->
        <WebBrowser x:Name="HelpBrowser" Grid.Column="1"
                    Navigating="HelpBrowser_Navigating"/>
    </Grid>
</Window>
