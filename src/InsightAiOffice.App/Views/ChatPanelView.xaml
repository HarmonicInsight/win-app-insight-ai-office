<UserControl x:Class="InsightAiOffice.App.Views.ChatPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:InsightAiOffice.App.Helpers">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Animated loading dots storyboard -->
        <Storyboard x:Key="LoadingDotsStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1.0" Duration="0:0:0.4" BeginTime="0:0:0.0" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1.0" Duration="0:0:0.4" BeginTime="0:0:0.15" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1.0" Duration="0:0:0.4" BeginTime="0:0:0.3" AutoReverse="True"/>
        </Storyboard>
    </UserControl.Resources>

    <Border Background="{StaticResource BgCardBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>                                <!-- 0: Header -->
                <RowDefinition Height="*"/>                                   <!-- 1: Chat Area -->
                <RowDefinition Height="Auto"/>                                <!-- 2: GridSplitter -->
                <RowDefinition Height="160" MinHeight="80" MaxHeight="400"/>  <!-- 3: Input Area -->
                <RowDefinition Height="Auto" MaxHeight="150"/>               <!-- 4: Artifacts -->
            </Grid.RowDefinitions>

            <!-- ═══ Row 0: Header ═══ -->
            <Border Grid.Row="0"
                    Background="{StaticResource PrimaryLightBrush}"
                    Padding="8,3"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <!-- Row 1: Title + action buttons -->
                    <DockPanel>
                        <!-- Right: action buttons -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Click="OpenArtifactFolder_Click"
                                    Background="White"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="5,2" Cursor="Hand"
                                    MinWidth="0" MinHeight="0" Margin="0,0,4,0"
                                    ToolTip="AIが作成したファイルのフォルダを開く">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3" Padding="{TemplateBinding Padding}" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8DA;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,3,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="OpenArtifactFolderLabel" Text="資料を見る" FontSize="9.5"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Click="PromptEditor_Click"
                                    Background="White"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="5,2" Cursor="Hand"
                                    MinWidth="0" MinHeight="0" Margin="0,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3" Padding="{TemplateBinding Padding}" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,3,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="PromptEditorLabel" Text="プロンプト" FontSize="9.5"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ClearChatHistoryCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="3,2"
                                    ToolTip="チャット履歴をクリア" MinWidth="0" MinHeight="0">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                            <Button Command="{Binding OpenAiSettingsCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="3,2"
                                    ToolTip="AI Settings" MinWidth="0" MinHeight="0">
                                <TextBlock Text="&#x2699;" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                            <Button Click="PopOut_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="3,2"
                                    ToolTip="別ウィンドウで開く" MinWidth="0" MinHeight="0">
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                            <Button Click="Close_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="3,2" Margin="2,0,0,0"
                                    MinWidth="0" MinHeight="0">
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </StackPanel>

                        <!-- Left: Title + Help -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PanelTitle}"
                                       FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Click="Help_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="2,1" Margin="4,0,0,0"
                                    MinWidth="0" MinHeight="0">
                                <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <!-- Row 2: Thread selector + DocBadge -->
                    <DockPanel Margin="0,3,0,0">
                        <!-- Right: Delete thread -->
                        <Button DockPanel.Dock="Right" Click="DeleteThread_Click"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="3,1" MinWidth="0" MinHeight="0"
                                ToolTip="スレッドを削除">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="{StaticResource ErrorBrush}"/>
                        </Button>
                        <!-- Right: Rename thread -->
                        <Button DockPanel.Dock="Right" Click="RenameThread_Click"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="3,1" MinWidth="0" MinHeight="0"
                                ToolTip="スレッド名を変更">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                        <!-- Left: New thread + ComboBox + DocBadge -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Click="NewThread_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="3,1" MinWidth="0" MinHeight="0"
                                    ToolTip="新しい会話を開始">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Button>
                            <ComboBox x:Name="ThreadCombo"
                                      ItemsSource="{Binding Threads}"
                                      SelectedItem="{Binding CurrentThread, Mode=TwoWay}"
                                      MinWidth="100" MaxWidth="200"
                                      FontSize="10" Margin="4,0,0,0"
                                      VerticalAlignment="Center"
                                      BorderThickness="0" Background="Transparent">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <!-- Context badge -->
                            <Border x:Name="DocBadge"
                                    Background="#F5F0E6" CornerRadius="3" Padding="5,1"
                                    VerticalAlignment="Center" Margin="6,0,0,0"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,3,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DocBadgeText" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               MaxWidth="100" TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ═══ Row 1: Chat Area ═══ -->
            <Grid Grid.Row="1">
                <!-- Welcome state: API未設定時のみ表示（ウェルカムはチャットバブルで表示するため通常は非表示） -->
                <StackPanel x:Name="WelcomeOverlay"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="24"
                            Visibility="Collapsed">
                    <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="ChatWelcomeText"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                </StackPanel>

                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="6,4">
                    <ItemsControl ItemsSource="{Binding ChatMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Outer container with hover trigger for action buttons -->
                                <Grid Margin="4,2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Bubble -->
                                        <RowDefinition Height="Auto"/> <!-- Hover actions -->
                                    </Grid.RowDefinitions>

                                    <!-- Message bubble -->
                                    <Border x:Name="MessageBubble" Grid.Row="0"
                                            Padding="10,7" MaxWidth="500"
                                            CornerRadius="10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}"/>
                                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                        <Setter Property="BorderBrush" Value="#E5C76B"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter Property="CornerRadius" Value="10,10,0,10"/>
                                                        <Setter Property="MaxWidth" Value="380"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                        <Setter Property="Background" Value="#FAF8F5"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                                        <Setter Property="CornerRadius" Value="10,10,10,0"/>
                                                        <Setter Property="MaxWidth" Value="500"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="System">
                                                        <Setter Property="Background" Value="#FFF8E1"/>
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                        <Setter Property="MaxWidth" Value="400"/>
                                                        <Setter Property="Padding" Value="10,5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <!-- Message content -->
                                            <TextBox Text="{Binding Content, Mode=OneWay}"
                                                     TextWrapping="Wrap"
                                                     FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     Background="Transparent" BorderThickness="0"
                                                     IsReadOnly="True" Cursor="Arrow">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="FontSize" Value="12.5"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Role}" Value="User">
                                                                <Setter Property="FontSize" Value="12"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Role}" Value="System">
                                                                <Setter Property="FontSize" Value="11"/>
                                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                                <Setter Property="FontStyle" Value="Italic"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>



                                            <!-- Insert to Document button removed — ユーザーはコピペで対応 -->
                                        </StackPanel>
                                    </Border>

                                    <!-- Action bar (Copy / Retry / Timestamp) — 常時表示 -->
                                    <StackPanel x:Name="ActionBar" Grid.Row="1"
                                                Orientation="Horizontal"
                                                Visibility="Visible"
                                                Margin="4,1,4,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <!-- Copy -->
                                        <Button Click="CopyMessage_Click" Tag="{Binding Content}"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Padding="4,2" MinWidth="0" MinHeight="0"
                                                Opacity="0.6" ToolTip="Copy">
                                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Button>
                                        <!-- Retry (Assistant only) -->
                                        <Button x:Name="RetryButton"
                                                Click="RetryMessage_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Padding="4,2" MinWidth="0" MinHeight="0"
                                                Opacity="0.6" Visibility="Collapsed"
                                                ToolTip="Retry">
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Button>
                                        <!-- Timestamp -->
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                   FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>

                                    <!-- ActionBar は常時表示のためホバートリガー不要 -->

                                    <Grid.Style>
                                        <Style TargetType="Grid"/>
                                    </Grid.Style>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                        <Setter TargetName="RetryButton" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ═══ Row 2: Splitter ═══ -->
            <GridSplitter Grid.Row="2" Height="5"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Background="Transparent" Cursor="SizeNS"
                          ResizeBehavior="PreviousAndNext"
                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"/>

            <!-- ═══ Row 3: Input Area ═══ -->
            <Border x:Name="InputAreaBorder" Grid.Row="3"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Processing indicator -->
                        <RowDefinition Height="*"/>     <!-- Input + Send -->
                        <RowDefinition Height="Auto"/>  <!-- Model indicator -->
                    </Grid.RowDefinitions>

                    <!-- Processing indicator with animated dots -->
                    <Border Grid.Row="0" Margin="0,0,0,4"
                            Background="#FDF6E3" CornerRadius="6" Padding="8,5"
                            Visibility="{Binding IsSending, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding CancelCommand}"
                                    FontSize="10" Padding="6,2"
                                    Background="Transparent" Foreground="{StaticResource ErrorBrush}"
                                    BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1"
                                    Cursor="Hand" VerticalAlignment="Center">
                                <TextBlock x:Name="CancelLabel"/>
                            </Button>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Animated dots -->
                                <Ellipse x:Name="Dot1" Width="5" Height="5" Fill="{StaticResource PrimaryBrush}"
                                         Opacity="0.3" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                <Ellipse x:Name="Dot2" Width="5" Height="5" Fill="{StaticResource PrimaryBrush}"
                                         Opacity="0.3" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                <Ellipse x:Name="Dot3" Width="5" Height="5" Fill="{StaticResource PrimaryBrush}"
                                         Opacity="0.3" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AiProcessingModelName}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AiProcessingText}"
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontStyle="Italic" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- 添付ファイル一覧 -->
                    <ItemsControl x:Name="AttachedFilesList" Margin="6,0,6,2">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,3,2" Padding="5,2" CornerRadius="3"
                                        Background="{StaticResource BgSecondaryBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        Cursor="Hand" ToolTip="{Binding FullPath}"
                                        Tag="{Binding FullPath}"
                                        MouseLeftButtonDown="OpenAttachment_DoubleClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,3,0" />
                                        <TextBlock Text="{Binding FileName}" FontSize="9"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                                        <Button Background="Transparent" BorderThickness="0"
                                                Padding="1,0" Margin="3,0,0,0" Cursor="Hand"
                                                Click="RemoveAttachment_Click" Tag="{Binding FullPath}">
                                            <TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="8" Foreground="{StaticResource TextTertiaryBrush}" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Input area -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Background="White"
                            AllowDrop="True" Drop="InputArea_Drop" DragOver="InputArea_DragOver">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- TextBox -->
                            <Grid Grid.Row="0">
                                <TextBox x:Name="ChatInput"
                                         Text="{Binding AiInput, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="12" Padding="10,8"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                                         VerticalAlignment="Stretch"
                                         KeyDown="ChatInput_KeyDown"
                                         AutomationProperties.Name="AI prompt input"/>
                                <TextBlock x:Name="PlaceholderText"
                                           IsHitTestVisible="False"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           FontSize="12" Padding="12,10"
                                           VerticalAlignment="Top"
                                           FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                                           Visibility="Collapsed"/>
                            </Grid>

                            <!-- Bottom toolbar: attach / theme / model / send -->
                            <DockPanel Grid.Row="1" Margin="4,0,4,4">
                                <!-- Right: Send -->
                                <Button DockPanel.Dock="Right" Padding="6,5" MinWidth="0" MinHeight="0"
                                        Cursor="Hand" Margin="4,0,0,0"
                                        Command="{Binding ExecuteFromInputCommand}"
                                        ToolTip="送信 (Enter)">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{StaticResource PrimaryBrush}"
                                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"/>
                                </Button>

                                <!-- Left controls -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Attach -->
                                    <Button Click="AttachFile_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Padding="4,3" MinWidth="0" MinHeight="0"
                                            ToolTip="ファイル添付">
                                        <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                    </Button>
                                    <!-- Separator -->
                                    <Border Width="1" Height="14" Background="{StaticResource BorderBrush}" Margin="4,0"/>
                                    <!-- Theme -->
                                    <ComboBox x:Name="ThemeColorCombo" FontSize="9" Width="70"
                                              VerticalAlignment="Center" BorderThickness="0" Background="Transparent"
                                              SelectionChanged="ThemeColor_SelectionChanged"
                                              ToolTip="生成テーマ">
                                        <ComboBoxItem Content="Gold" Tag="gold" IsSelected="True" />
                                        <ComboBoxItem Content="Blue" Tag="blue" />
                                        <ComboBoxItem Content="Green" Tag="green" />
                                        <ComboBoxItem Content="Navy" Tag="navy" />
                                        <ComboBoxItem Content="Mono" Tag="mono" />
                                    </ComboBox>
                                    <!-- Separator -->
                                    <Border Width="1" Height="14" Background="{StaticResource BorderBrush}" Margin="2,0"/>
                                    <!-- Model -->
                                    <ComboBox x:Name="ModelCombo" FontSize="9" Width="95"
                                              VerticalAlignment="Center" BorderThickness="0" Background="Transparent"
                                              SelectionChanged="ModelCombo_SelectionChanged"
                                              ToolTip="AIモデル選択"/>
                                </StackPanel>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ Row 4: Artifacts ═══ -->
            <Border Grid.Row="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid x:Name="ArtifactSection" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="8,4,8,2">
                        <TextBlock Text="成果物" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Click="OpenArtifactFolder_Click"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Padding="4,2" ToolTip="フォルダを開く" HorizontalAlignment="Right">
                            <TextBlock Text="&#xE8DA;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </DockPanel>
                    <ItemsControl Grid.Row="1" x:Name="ArtifactList" Margin="4,0,4,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,1" Padding="6,4" CornerRadius="4" Cursor="Hand"
                                        Background="{StaticResource BgSecondaryBrush}"
                                        MouseLeftButtonUp="ArtifactItem_Click"
                                        Tag="{Binding FilePath}">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="&#xE8A7;"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding FileName}" FontSize="10"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
