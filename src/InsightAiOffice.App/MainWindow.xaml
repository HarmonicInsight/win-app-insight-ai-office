<Window x:Class="InsightAiOffice.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:rte="clr-namespace:Syncfusion.Windows.Controls.RichTextBoxAdv;assembly=Syncfusion.SfRichTextBoxAdv.WPF"
        xmlns:pdfviewer="clr-namespace:Syncfusion.Windows.PdfViewer;assembly=Syncfusion.PdfViewer.WPF"
        xmlns:ui="clr-namespace:InsightCommon.UI;assembly=InsightCommon"
        xmlns:helpers="clr-namespace:InsightAiOffice.App.Helpers"
        xmlns:views="clr-namespace:InsightAiOffice.App.Views"
        Title="Insight AI Office"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        AllowDrop="True"
        Drop="OnFileDrop"
        DragOver="OnDragOver">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewDocumentCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenDocumentCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveDocumentCommand}"/>
        <KeyBinding Key="F1" Command="{Binding ShowHelpCommand}"/>
        <KeyBinding Key="OemPlus" Modifiers="Ctrl" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Key="OemMinus" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Key="D0" Modifiers="Ctrl" Command="{Binding ResetZoomCommand}"/>
    </Window.InputBindings>

    <Border Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>

            <!-- ═══ Custom TitleBar (Row 0) ═══ -->
            <Border Grid.Row="0" Background="{StaticResource BgCardBrush}"
                    CornerRadius="8,8,0,0" Panel.ZIndex="10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Product name, version, plan badge -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="Insight" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="AI Office" FontSize="15" FontWeight="Normal"
                                   Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <TextBlock x:Name="VersionLabel" Text="v1.0.0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <Border x:Name="PlanBadge" Background="#F5F5F4"
                                CornerRadius="4" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                Cursor="Hand" MouseLeftButtonUp="LicenseButton_Click">
                            <TextBlock x:Name="PlanBadgeText" Text="FREE" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#A8A29E"/>
                        </Border>
                        <TextBlock Text="—" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="10,0,8,0"/>
                        <TextBlock x:Name="FileNameLabel"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                    </StackPanel>

                    <!-- Center: Panel toggle buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="ChatToggleBtn" Click="ToggleChatPane_Click"
                                Style="{StaticResource TitleBarButtonStyle}" Height="32" Width="Auto" Padding="8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="ChatToggleText" Text="AI コンシェルジュ" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Right: Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinimizeBtn" Content="&#xE949;" Click="MinimizeButton_Click"
                                Style="{StaticResource WindowControlButtonStyle}"/>
                        <Button x:Name="MaximizeButton" Content="&#xE739;" Click="MaximizeButton_Click"
                                Style="{StaticResource WindowControlButtonStyle}"/>
                        <Button x:Name="CloseBtn" Content="&#xE106;" Click="CloseButton_Click"
                                Style="{StaticResource CloseButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Default Ribbon (Row 1) — visible when no file is open ═══ -->
            <Border x:Name="DefaultRibbonPanel" Grid.Row="1" ClipToBounds="True">
            <syncfusion:Ribbon x:Name="MainRibbon"
                               ShowCustomizeRibbon="False"
                               EnableSimplifiedLayoutMode="False"
                               BackStageHeader="ファイル"
                               BackStageColor="{StaticResource PrimaryBrush}">
                <syncfusion:Ribbon.Items>
                    <syncfusion:RibbonTab Caption="ホーム" IsChecked="True">
                        <syncfusion:RibbonBar Header="ファイル">
                            <syncfusion:RibbonButton Label="開く" SizeForm="Large" Command="{Binding OpenDocumentCommand}" ToolTip="ファイルを開く (Ctrl+O)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="ヘルプ">
                            <syncfusion:RibbonButton Label="チュートリアル" SizeForm="Large" Click="Tutorial_Click" ToolTip="サンプルデータで機能を体験">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource PrimaryBrush}"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="ヘルプ" SizeForm="Small" Click="RibbonHelp_Click" ToolTip="ヘルプ (F1)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                    </syncfusion:RibbonTab>
                </syncfusion:Ribbon.Items>
                <syncfusion:Ribbon.BackStage>
                    <syncfusion:Backstage Background="{StaticResource BgPrimaryBrush}">
                        <syncfusion:BackStageCommandButton x:Name="BS_Open" Header="開く" Click="BackstageOpen_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackstageTabItem x:Name="BS_RecentTab" Header="最近使ったファイル" IsSelected="True">
                            <StackPanel Margin="24,16" Width="450" HorizontalAlignment="Left">
                                <TextBlock x:Name="BS_RecentTitle" Text="最近使ったファイル" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                <ListBox x:Name="RecentFilesList" Background="Transparent" BorderThickness="0"
                                         MouseDoubleClick="RecentFile_DoubleClick" Padding="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="RecentFile_Click" Tag="{Binding FilePath}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    HorizontalContentAlignment="Left" Padding="8,6" Width="420">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FileName}" FontSize="13"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding FilePath}" FontSize="10"
                                                               Foreground="{StaticResource TextTertiaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock x:Name="RecentFilesEmptyHint" Text="まだファイルを開いていません"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="8,16,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </syncfusion:BackstageTabItem>
                        <syncfusion:BackStageCommandButton x:Name="BS_Settings" Header="設定" Click="BackstageSettings_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageSeparator/>
                        <syncfusion:BackstageTabItem x:Name="BS_LanguageTab" Header="言語 / Language">
                            <StackPanel Margin="24,16" Width="350" HorizontalAlignment="Left">
                                <TextBlock x:Name="BS_LanguageTitle" Text="言語 / Language" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                <RadioButton x:Name="LangJapanese" Content="日本語" Tag="ja"
                                             GroupName="Language" IsChecked="True"
                                             FontSize="14" Margin="0,0,0,8"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             Click="LanguageRadio_Click"/>
                                <RadioButton x:Name="LangEnglish" Content="English" Tag="en"
                                             GroupName="Language"
                                             FontSize="14" Margin="0,0,0,8"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             Click="LanguageRadio_Click"/>
                            </StackPanel>
                        </syncfusion:BackstageTabItem>
                        <syncfusion:BackstageTabItem x:Name="BS_LicenseTab" Header="ライセンス">
                            <StackPanel Margin="24,16" Width="350" HorizontalAlignment="Left">
                                <TextBlock x:Name="LicenseTitleText" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <Border Background="#FBF7F0" CornerRadius="6" Padding="16,12" Margin="0,8,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="CurrentPlanLabel" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="LicensePlanText" Text="FREE" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="LicenseExpiryText" Text="" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="LicenseOpenBtn" Click="BackstageLicense_Click"
                                        Padding="16,8" FontSize="13" Cursor="Hand"
                                        Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </syncfusion:BackstageTabItem>
                        <syncfusion:BackStageSeparator/>
                        <syncfusion:BackStageCommandButton x:Name="BS_CloseDoc" Header="ドキュメントを閉じる" Click="BackstageCloseDoc_Click" IsEnabled="{Binding IsFileLoaded}">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                    </syncfusion:Backstage>
                </syncfusion:Ribbon.BackStage>
            </syncfusion:Ribbon>
            </Border>

            <!-- ═══ Word Ribbon (Row 1) ═══ -->
            <Border x:Name="WordRibbonPanel" Grid.Row="1" ClipToBounds="True" Visibility="Collapsed">
            <syncfusion:Ribbon x:Name="WordRibbon"
                               ShowCustomizeRibbon="False"
                               EnableSimplifiedLayoutMode="False"
                               BackStageHeader="ファイル"
                               BackStageColor="{StaticResource PrimaryBrush}">
                <syncfusion:Ribbon.Items>
                    <syncfusion:RibbonTab Caption="ホーム" IsChecked="True">
                        <syncfusion:RibbonBar Header="ファイル">
                            <syncfusion:RibbonButton Label="開く" SizeForm="Small" Command="{Binding OpenDocumentCommand}" ToolTip="ファイルを開く (Ctrl+O)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="保存" SizeForm="Small" Command="{Binding SaveDocumentCommand}" ToolTip="上書き保存 (Ctrl+S)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="名前を付けて保存" SizeForm="Small" Click="ExportWord_Click" ToolTip="名前を付けて保存">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="元に戻す">
                            <syncfusion:RibbonButton Label="元に戻す" SizeForm="Small" Click="WordUndo_Click" ToolTip="元に戻す (Ctrl+Z)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="やり直し" SizeForm="Small" Click="WordRedo_Click" ToolTip="やり直し (Ctrl+Y)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="フォント">
                            <syncfusion:RibbonButton Label="太字" SizeForm="Small" Click="FormatBold_Click" ToolTip="太字 (Ctrl+B)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="B" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="斜体" SizeForm="Small" Click="FormatItalic_Click" ToolTip="斜体 (Ctrl+I)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="I" FontFamily="Segoe UI" FontSize="14" FontStyle="Italic"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="下線" SizeForm="Small" Click="FormatUnderline_Click" ToolTip="下線 (Ctrl+U)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="U" FontFamily="Segoe UI" FontSize="14" TextDecorations="Underline"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="取り消し線" SizeForm="Small" Click="FormatStrikethrough_Click" ToolTip="取り消し線">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="S" FontFamily="Segoe UI" FontSize="14" TextDecorations="Strikethrough"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="段落">
                            <syncfusion:RibbonButton Label="左揃え" SizeForm="Small" Click="WordAlignLeft_Click" ToolTip="左揃え">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8E4;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="中央揃え" SizeForm="Small" Click="WordAlignCenter_Click" ToolTip="中央揃え">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8E3;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="右揃え" SizeForm="Small" Click="WordAlignRight_Click" ToolTip="右揃え">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8E2;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="箇条書き" SizeForm="Small" Click="WordBulletList_Click" ToolTip="箇条書き">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="挿入">
                            <syncfusion:RibbonButton Label="画像挿入" SizeForm="Large" Click="WordInsertImage_Click" ToolTip="画像を挿入">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="編集">
                            <syncfusion:RibbonButton Label="検索と置換" SizeForm="Large" Click="FindReplace_Click" ToolTip="検索と置換 (Ctrl+H)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="印刷">
                            <syncfusion:RibbonButton Label="印刷" SizeForm="Large" Click="BackstagePrint_Click" ToolTip="印刷 (Ctrl+P)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="ヘルプ">
                            <syncfusion:RibbonButton Label="ヘルプ" SizeForm="Large" Click="RibbonHelp_Click">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                    </syncfusion:RibbonTab>
                </syncfusion:Ribbon.Items>
                <syncfusion:Ribbon.BackStage>
                    <syncfusion:Backstage Background="{StaticResource BgPrimaryBrush}">
                        <syncfusion:BackStageCommandButton Header="開く" Click="BackstageOpen_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageCommandButton Header="上書き保存" Command="{Binding SaveDocumentCommand}">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageCommandButton Header="印刷" Click="BackstagePrint_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackstageTabItem x:Name="WordRecentTab" Header="最近使ったファイル" IsSelected="True">
                            <StackPanel Margin="24,16" Width="450" HorizontalAlignment="Left">
                                <TextBlock x:Name="WordRecentTitle" Text="最近使ったファイル" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                <ListBox x:Name="WordRecentFilesList" Background="Transparent" BorderThickness="0"
                                         MouseDoubleClick="RecentFile_DoubleClick" Padding="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="RecentFile_Click" Tag="{Binding FilePath}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    HorizontalContentAlignment="Left" Padding="8,6" Width="420">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FileName}" FontSize="13"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding FilePath}" FontSize="10"
                                                               Foreground="{StaticResource TextTertiaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock x:Name="WordRecentEmptyHint" Text="まだファイルを開いていません"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="8,16,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </syncfusion:BackstageTabItem>
                        <syncfusion:BackStageCommandButton Header="設定" Click="BackstageSettings_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageSeparator/>
                        <syncfusion:BackstageTabItem x:Name="WordLanguageTab" Header="言語 / Language">
                            <StackPanel Margin="24,16" Width="350" HorizontalAlignment="Left">
                                <TextBlock Text="言語 / Language" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                <RadioButton Content="日本語" Tag="ja" GroupName="WordLanguage" IsChecked="True"
                                             FontSize="14" Margin="0,0,0,8" Foreground="{StaticResource TextPrimaryBrush}" Click="LanguageRadio_Click"/>
                                <RadioButton Content="English" Tag="en" GroupName="WordLanguage"
                                             FontSize="14" Margin="0,0,0,8" Foreground="{StaticResource TextPrimaryBrush}" Click="LanguageRadio_Click"/>
                            </StackPanel>
                        </syncfusion:BackstageTabItem>
                        <syncfusion:BackstageTabItem x:Name="WordLicenseTab" Header="ライセンス">
                            <StackPanel Margin="24,16" Width="350" HorizontalAlignment="Left">
                                <TextBlock x:Name="WordLicenseTitleText" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" Text="ライセンス"/>
                                <Border Background="#FBF7F0" CornerRadius="6" Padding="16,12" Margin="0,8,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="WordCurrentPlanLabel" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="現在のプラン"/>
                                        <TextBlock x:Name="WordLicensePlanText" Text="FREE" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="WordLicenseExpiryText" Text="" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="WordLicenseOpenBtn" Click="BackstageLicense_Click"
                                        Padding="16,8" FontSize="13" Cursor="Hand"
                                        Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0" Content="ライセンス管理"/>
                            </StackPanel>
                        </syncfusion:BackstageTabItem>
                        <syncfusion:BackStageCommandButton Header="ドキュメントを閉じる" Click="BackstageCloseDoc_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                    </syncfusion:Backstage>
                </syncfusion:Ribbon.BackStage>
            </syncfusion:Ribbon>
            </Border>

            <!-- ═══ Excel Ribbon (Row 1) ═══ -->
            <Border x:Name="ExcelRibbonPanel" Grid.Row="1" ClipToBounds="True" Visibility="Collapsed">
            <syncfusion:Ribbon x:Name="ExcelRibbon"
                               ShowCustomizeRibbon="False"
                               EnableSimplifiedLayoutMode="False"
                               BackStageHeader="ファイル"
                               BackStageColor="{StaticResource PrimaryBrush}">
                <syncfusion:Ribbon.Items>
                    <syncfusion:RibbonTab Caption="ホーム" IsChecked="True">
                        <syncfusion:RibbonBar Header="ファイル">
                            <syncfusion:RibbonButton Label="開く" SizeForm="Small" Command="{Binding OpenDocumentCommand}" ToolTip="ファイルを開く">
