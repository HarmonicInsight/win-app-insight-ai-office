                                <TextBlock x:Name="PdfRecentTitle" Text="最近使ったファイル" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                <ListBox x:Name="PdfRecentFilesList" Background="Transparent" BorderThickness="0"
                                         MouseDoubleClick="RecentFile_DoubleClick" Padding="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="RecentFile_Click" Tag="{Binding FilePath}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    HorizontalContentAlignment="Left" Padding="8,6" Width="420">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FileName}" FontSize="13"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding FilePath}" FontSize="10"
                                                               Foreground="{StaticResource TextTertiaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock x:Name="PdfRecentEmptyHint" Text="まだファイルを開いていません"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="8,16,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </syncfusion:BackstageTabItem>
                        <syncfusion:BackStageCommandButton Header="設定" Click="BackstageSettings_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageCommandButton Header="ドキュメントを閉じる" Click="BackstageCloseDoc_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                    </syncfusion:Backstage>
                </syncfusion:Ribbon.BackStage>
            </syncfusion:Ribbon>
            </Border>

            <!-- ═══ Main Content Area (Row 2) — 2-Pane Layout ═══ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>     <!-- center -->
                    <ColumnDefinition Width="Auto"/>  <!-- right splitter -->
                    <ColumnDefinition x:Name="RightPanelCol" Width="0" MinWidth="0"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ Center: Document Editor Area ═══ -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Document Tab Bar -->
                    <Border x:Name="TabBarPanel" Grid.Row="0" Visibility="Collapsed"
                            Background="{StaticResource BgSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                      VerticalAlignment="Bottom">
                            <StackPanel x:Name="TabBarItems" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Editor Panels Container -->
                    <Grid Grid.Row="1">
                    <!-- Welcome Panel (visible when no file is open) -->
                    <Border x:Name="WelcomePanel" Background="{StaticResource BgPrimaryBrush}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
                            <TextBlock Text="Insight" FontSize="36" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="AI Office" FontSize="28" FontWeight="Light"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="WelcomeTagline" Text="AI の民主化：誰もが業務で AI を使えるように"
                                       FontSize="14" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,28"/>

                            <!-- 2 Feature Cards -->
                            <UniformGrid Columns="2" Margin="0,0,0,20">
                                <!-- Card 1: Edit Office -->
                                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="20,16"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                                   Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="WelcomeEditTitle" Text="オフィスを編集する"
                                                   FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                        <TextBlock x:Name="WelcomeEditDesc"
                                                   Text="Word・Excel を直接編集&#x0a;PowerPoint のスライドを操作"
                                                   FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <!-- Card 2: Create New -->
                                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="20,16"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="6,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                                   Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="WelcomeCreateTitle" Text="新しい資料を作る"
                                                   FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                        <TextBlock x:Name="WelcomeCreateDesc"
                                                   Text="AI が要約・分析・翻訳して&#x0a;レポートやグラフを自動生成"
                                                   FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Action Buttons -->
                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="24,16"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <Button Command="{Binding OpenDocumentCommand}" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Width="28"/>
                                            <StackPanel>
                                                <TextBlock x:Name="WelcomeOpenLabel" Text="ファイルを開いて編集する" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="WelcomeOpenDesc" Text=".docx / .xlsx / .pptx / .pdf を開いて AI と一緒に作業"
                                                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>

                                    <Button Click="ToggleChatPane_Click" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Width="28"/>
                                            <StackPanel>
                                                <TextBlock x:Name="WelcomeChatLabel" Text="AI コンシェルジュで資料を作成" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="WelcomeChatDesc" Text="要約・分析・翻訳 → レポート・グラフ・表を自動生成" FontSize="11"
                                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="WelcomeDragHint" Text="ファイルをドラッグ＆ドロップでも開けます"
                                       FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Word Editor Panel -->
                    <Grid x:Name="WordEditorPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="12,4">
                            <Grid>
                                <TextBlock x:Name="WordFileName" Text="" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                        Click="CloseEditor_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <rte:SfRichTextBoxAdv x:Name="RichTextEditor" Grid.Row="1" IsReadOnly="False" Background="#F0F0F0"/>
                    </Grid>

                    <!-- Excel Editor Panel -->
                    <Grid x:Name="ExcelEditorPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="12,4">
                            <Grid>
                                <TextBlock x:Name="ExcelFileName" Text="" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                        Click="CloseEditor_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <syncfusion:SfSpreadsheet x:Name="Spreadsheet" Grid.Row="1"/>
                    </Grid>

                    <!-- PPTX Slide Viewer Panel -->
                    <Grid x:Name="PptxInfoPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Header bar -->
                        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="12,4">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="PptxFileName" Text="" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PptxSlideCount" Text="" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                        Click="CloseEditor_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <!-- Slide thumbnails (left) + Main slide view (center) -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Slide thumbnail list -->
                            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                                    Background="{StaticResource BgSecondaryBrush}">
                                <ListBox x:Name="PptxSlideList" SelectionChanged="PptxSlideList_SelectionChanged"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         HorizontalContentAlignment="Center" Padding="4">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2,4">
                                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        Background="White" HorizontalAlignment="Center">
                                                    <Image Source="{Binding Thumbnail}" Width="130" Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>
                                                <TextBlock Text="{Binding Label}" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            <!-- Main slide image -->
                            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto" Background="#F0F0F0">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                                    <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.2" Color="Black"/>
                                        </Border.Effect>
                                        <Image x:Name="PptxMainSlideImage" Stretch="Uniform"
                                               MaxWidth="900" MaxHeight="680"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- PDF Viewer Panel -->
                    <Grid x:Name="PdfViewerPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="12,4">
                            <Grid>
                                <TextBlock x:Name="PdfFileName" Text="" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                        Click="CloseEditor_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <pdfviewer:PdfViewerControl x:Name="PdfViewer" Grid.Row="1"/>
                    </Grid>

                    </Grid> <!-- End Editor Panels Container -->
                </Grid>

                <!-- Right Splitter -->
                <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"/>

                <!-- ═══ Right Panel: AI Chat ═══ -->
                <views:ChatPanelView x:Name="ChatPanel" Grid.Column="2"/>
            </Grid>

            <!-- ═══ Status Bar (Row 3) ═══ -->
            <Border Grid.Row="3" Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText" Grid.Column="0" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FileTypeLabel" Grid.Column="1" FontSize="11" Margin="12,0"
                               Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionText" Grid.Column="2" FontSize="11" Margin="12,0"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" FontSize="11"
                               Text="{Binding Source={x:Static ui:InsightScaleManager.Instance}, Path=ScalePercent}"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
