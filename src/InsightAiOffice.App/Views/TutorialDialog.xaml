<Window x:Class="InsightAiOffice.App.Views.TutorialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="チュートリアル — Insight AI Office"
        Width="920" Height="460" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{StaticResource BgPrimaryBrush}"
        FontFamily="Yu Gothic UI, Meiryo, Segoe UI">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}">
                <Run Text="&#xE82D;" FontFamily="Segoe MDL2 Assets"/>
                <Run Text=" チュートリアル"/>
            </TextBlock>
            <TextBlock Text="カードをクリックすると、サンプルデータ付きでAIが自動実行されます"
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Cards (3列 × 2行) -->
        <WrapPanel x:Name="CardPanel" Grid.Row="1" Orientation="Horizontal"/>

        <!-- Footer -->
        <Button Grid.Row="2" Content="閉じる" Click="Close_Click"
                HorizontalAlignment="Right" Margin="0,12,0,0"
                Padding="20,6" Cursor="Hand"
                Background="{StaticResource PrimaryBrush}" Foreground="White"
                BorderThickness="0" FontSize="12"/>
    </Grid>
</Window>
