<Window x:Class="InsightAiOffice.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:rte="clr-namespace:Syncfusion.Windows.Controls.RichTextBoxAdv;assembly=Syncfusion.SfRichTextBoxAdv.WPF"
        xmlns:ui="clr-namespace:InsightCommon.UI;assembly=InsightCommon"
        xmlns:helpers="clr-namespace:InsightAiOffice.App.Helpers"
        xmlns:views="clr-namespace:InsightAiOffice.App.Views"
        Title="Insight AI Office"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        AllowDrop="True"
        Drop="OnFileDrop"
        DragOver="OnDragOver">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewDocumentCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenDocumentCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveDocumentCommand}"/>
        <KeyBinding Key="F1" Command="{Binding ShowHelpCommand}"/>
        <KeyBinding Key="OemPlus" Modifiers="Ctrl" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Key="OemMinus" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Key="D0" Modifiers="Ctrl" Command="{Binding ResetZoomCommand}"/>
    </Window.InputBindings>

    <Border Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>

            <!-- ═══ Custom TitleBar (Row 0) ═══ -->
            <Border Grid.Row="0" Background="{StaticResource BgCardBrush}"
                    CornerRadius="8,8,0,0" Panel.ZIndex="10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Product name, version, plan badge -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="Insight" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="AI Office" FontSize="15" FontWeight="Normal"
                                   Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <TextBlock x:Name="VersionLabel" Text="v1.0.0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <Border x:Name="PlanBadge" Background="#F5F5F4"
                                CornerRadius="4" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                Cursor="Hand" MouseLeftButtonUp="LicenseButton_Click">
                            <TextBlock x:Name="PlanBadgeText" Text="FREE" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#A8A29E"/>
                        </Border>
                        <TextBlock Text="—" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="10,0,8,0"/>
                        <TextBlock x:Name="FileNameLabel"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                    </StackPanel>

                    <!-- Center: Panel toggle buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="ChatToggleBtn" Click="ToggleChatPane_Click"
                                Style="{StaticResource TitleBarButtonStyle}" Height="32" Width="Auto" Padding="8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="ChatToggleText" Text="AI" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Click="TogglePromptPane_Click" x:Name="PromptToggleBtn"
                                Style="{StaticResource TitleBarButtonStyle}" Height="32" Width="Auto" Padding="8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="PromptToggleText" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Click="ToggleReferencePane_Click" x:Name="RefToggleBtn"
                                Style="{StaticResource TitleBarButtonStyle}" Height="32" Width="Auto" Padding="8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="RefToggleText" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Right: Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinimizeBtn" Content="&#xE949;" Click="MinimizeButton_Click"
                                Style="{StaticResource WindowControlButtonStyle}"/>
                        <Button x:Name="MaximizeButton" Content="&#xE739;" Click="MaximizeButton_Click"
                                Style="{StaticResource WindowControlButtonStyle}"/>
                        <Button x:Name="CloseBtn" Content="&#xE106;" Click="CloseButton_Click"
                                Style="{StaticResource CloseButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Default Ribbon (Row 1) — visible when no file is open ═══ -->
            <Border x:Name="DefaultRibbonPanel" Grid.Row="1" ClipToBounds="True">
            <syncfusion:Ribbon x:Name="MainRibbon"
                               ShowCustomizeRibbon="False"
                               EnableSimplifiedLayoutMode="False"
                               BackStageHeader="ファイル"
                               BackStageColor="{StaticResource PrimaryBrush}">
                <syncfusion:Ribbon.Items>
                    <syncfusion:RibbonTab Caption="ホーム" IsChecked="True">
                        <syncfusion:RibbonBar Header="ファイル">
                            <syncfusion:RibbonButton Label="開く" SizeForm="Large" Command="{Binding OpenDocumentCommand}" ToolTip="ファイルを開く (Ctrl+O)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="AI">
                            <syncfusion:RibbonButton Label="AI チャット" SizeForm="Large" Click="ToggleChatPane_Click" ToolTip="AI コンシェルジュを開く"
                                                     AutomationProperties.Name="AIチャット">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="AI 文書生成" SizeForm="Large" Click="AiGenerateDoc_Click" ToolTip="AI でドキュメントを自動生成"
                                                     AutomationProperties.Name="AI文書生成">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="横断分析" SizeForm="Large" Click="CrossFormatAnalysis_Click" ToolTip="ドキュメント＋参考資料を横断的に AI 分析"
                                                     AutomationProperties.Name="クロスフォーマット分析">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="AI 設定" SizeForm="Large" Click="AiSettings_Click" ToolTip="AI プロバイダー・モデル・API キーの設定"
                                                     AutomationProperties.Name="AI設定">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="ヘルプ">
                            <syncfusion:RibbonButton Label="ヘルプ" SizeForm="Large" Click="RibbonHelp_Click">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                    </syncfusion:RibbonTab>
                </syncfusion:Ribbon.Items>
                <syncfusion:Ribbon.BackStage>
                    <syncfusion:Backstage Background="{StaticResource BgPrimaryBrush}">
                        <syncfusion:BackStageCommandButton x:Name="BS_Open" Header="開く" Command="{Binding OpenDocumentCommand}">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageCommandButton x:Name="BS_ProjectSave" Header="プロジェクト保存 (.iaof)" Click="SaveAsProject_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageCommandButton x:Name="BS_Settings" Header="設定" Click="BackstageSettings_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageSeparator/>
                        <syncfusion:BackstageTabItem x:Name="BS_LanguageTab" Header="言語 / Language">
                            <StackPanel Margin="24,16" Width="350" HorizontalAlignment="Left">
                                <TextBlock x:Name="BS_LanguageTitle" Text="言語 / Language" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                <RadioButton x:Name="LangJapanese" Content="日本語" Tag="ja"
                                             GroupName="Language" IsChecked="True"
                                             FontSize="14" Margin="0,0,0,8"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             Click="LanguageRadio_Click"/>
                                <RadioButton x:Name="LangEnglish" Content="English" Tag="en"
                                             GroupName="Language"
                                             FontSize="14" Margin="0,0,0,8"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             Click="LanguageRadio_Click"/>
                            </StackPanel>
                        </syncfusion:BackstageTabItem>
                        <syncfusion:BackstageTabItem x:Name="BS_LicenseTab" Header="ライセンス">
                            <StackPanel Margin="24,16" Width="350" HorizontalAlignment="Left">
                                <TextBlock x:Name="LicenseTitleText" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <Border Background="#FBF7F0" CornerRadius="6" Padding="16,12" Margin="0,8,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="CurrentPlanLabel" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="LicensePlanText" Text="FREE" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="LicenseExpiryText" Text="" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="LicenseOpenBtn" Click="BackstageLicense_Click"
                                        Padding="16,8" FontSize="13" Cursor="Hand"
                                        Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </syncfusion:BackstageTabItem>
                        <syncfusion:BackStageSeparator/>
                        <syncfusion:BackStageCommandButton x:Name="BS_CloseDoc" Header="ドキュメントを閉じる" Click="BackstageCloseDoc_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                    </syncfusion:Backstage>
                </syncfusion:Ribbon.BackStage>
            </syncfusion:Ribbon>
            </Border>

            <!-- ═══ Word Ribbon (Row 1) ═══ -->
            <Border x:Name="WordRibbonPanel" Grid.Row="1" ClipToBounds="True" Visibility="Collapsed">
            <syncfusion:Ribbon x:Name="WordRibbon"
                               ShowCustomizeRibbon="False"
                               EnableSimplifiedLayoutMode="False"
                               BackStageHeader="ファイル"
                               BackStageColor="{StaticResource PrimaryBrush}">
                <syncfusion:Ribbon.Items>
                    <syncfusion:RibbonTab Caption="ホーム" IsChecked="True">
                        <syncfusion:RibbonBar Header="ファイル">
                            <syncfusion:RibbonButton Label="開く" SizeForm="Small" Command="{Binding OpenDocumentCommand}" ToolTip="ファイルを開く (Ctrl+O)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="保存" SizeForm="Small" Command="{Binding SaveDocumentCommand}" ToolTip="上書き保存 (Ctrl+S)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="名前を付けて保存" SizeForm="Small" Click="ExportWord_Click" ToolTip="名前を付けて保存">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="エクスポート">
                            <syncfusion:RibbonButton Label="Word" SizeForm="Large" Click="ExportWord_Click" ToolTip="Word (.docx) としてエクスポート">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="フォント">
                            <syncfusion:RibbonButton Label="太字" SizeForm="Small" Click="FormatBold_Click" ToolTip="太字 (Ctrl+B)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="B" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="斜体" SizeForm="Small" Click="FormatItalic_Click" ToolTip="斜体 (Ctrl+I)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="I" FontFamily="Segoe UI" FontSize="14" FontStyle="Italic"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="下線" SizeForm="Small" Click="FormatUnderline_Click" ToolTip="下線 (Ctrl+U)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="U" FontFamily="Segoe UI" FontSize="14" TextDecorations="Underline"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="段落">
                            <syncfusion:RibbonButton Label="左揃え" SizeForm="Small" Click="WordAlignLeft_Click" ToolTip="左揃え">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8E4;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="中央揃え" SizeForm="Small" Click="WordAlignCenter_Click" ToolTip="中央揃え">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8E3;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="右揃え" SizeForm="Small" Click="WordAlignRight_Click" ToolTip="右揃え">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8E2;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="編集">
                            <syncfusion:RibbonButton Label="検索と置換" SizeForm="Large" Click="FindReplace_Click" ToolTip="検索と置換 (Ctrl+H)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="印刷">
                            <syncfusion:RibbonButton Label="印刷" SizeForm="Large" Click="BackstagePrint_Click" ToolTip="印刷 (Ctrl+P)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                    </syncfusion:RibbonTab>
                    <syncfusion:RibbonTab Caption="AI">
                        <syncfusion:RibbonBar Header="AI アシスタント">
                            <syncfusion:RibbonButton Label="AI チャット" SizeForm="Large" Click="ToggleChatPane_Click" ToolTip="AI コンシェルジュを開く">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="要約" SizeForm="Large" Click="AiSummarize_Click" ToolTip="ドキュメント要約">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="校正" SizeForm="Large" Click="AiProofread_Click" ToolTip="文章校正">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="分析" SizeForm="Large" Click="AiAnalyze_Click" ToolTip="構造分析">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="横断分析" SizeForm="Large" Click="CrossFormatAnalysis_Click" ToolTip="ドキュメント＋参考資料を横断的に AI 分析">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="プロンプト・資料">
                            <syncfusion:RibbonButton Label="プロンプト管理" SizeForm="Large" Click="TogglePromptPane_Click" ToolTip="プロンプトの作成・管理">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="参考資料" SizeForm="Large" Click="ToggleReferencePane_Click" ToolTip="参考資料パネルを開く">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="AI 設定">
                            <syncfusion:RibbonButton Label="AI 設定" SizeForm="Large" Click="AiSettings_Click" ToolTip="AI プロバイダー・モデル・API キーの設定">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                    </syncfusion:RibbonTab>
                </syncfusion:Ribbon.Items>
                <syncfusion:Ribbon.BackStage>
                    <syncfusion:Backstage Background="{StaticResource BgPrimaryBrush}">
                        <syncfusion:BackStageCommandButton Header="開く" Command="{Binding OpenDocumentCommand}">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageCommandButton Header="上書き保存" Command="{Binding SaveDocumentCommand}">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageCommandButton Header="印刷" Click="BackstagePrint_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageSeparator/>
                        <syncfusion:BackStageCommandButton Header="ドキュメントを閉じる" Click="BackstageCloseDoc_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                    </syncfusion:Backstage>
                </syncfusion:Ribbon.BackStage>
            </syncfusion:Ribbon>
            </Border>

            <!-- ═══ Excel Ribbon (Row 1) ═══ -->
            <Border x:Name="ExcelRibbonPanel" Grid.Row="1" ClipToBounds="True" Visibility="Collapsed">
            <syncfusion:Ribbon x:Name="ExcelRibbon"
                               ShowCustomizeRibbon="False"
                               EnableSimplifiedLayoutMode="False"
                               BackStageHeader="ファイル"
                               BackStageColor="{StaticResource PrimaryBrush}">
                <syncfusion:Ribbon.Items>
                    <syncfusion:RibbonTab Caption="ホーム" IsChecked="True">
                        <syncfusion:RibbonBar Header="ファイル">
                            <syncfusion:RibbonButton Label="開く" SizeForm="Small" Command="{Binding OpenDocumentCommand}" ToolTip="ファイルを開く">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="保存" SizeForm="Small" Click="ExportExcel_Click" ToolTip="名前を付けて保存">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="クリップボード">
                            <syncfusion:RibbonButton Label="貼り付け" SizeForm="Large" Click="ExcelPaste_Click" ToolTip="貼り付け (Ctrl+V)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="切り取り" SizeForm="Small" Click="ExcelCut_Click" ToolTip="切り取り (Ctrl+X)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="コピー" SizeForm="Small" Click="ExcelCopy_Click" ToolTip="コピー (Ctrl+C)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="フォント">
                            <syncfusion:RibbonButton Label="太字" SizeForm="Small" Click="ExcelBold_Click" ToolTip="太字">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="B" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="斜体" SizeForm="Small" Click="ExcelItalic_Click" ToolTip="斜体">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="I" FontFamily="Segoe UI" FontSize="14" FontStyle="Italic"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="下線" SizeForm="Small" Click="ExcelUnderline_Click" ToolTip="下線">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="U" FontFamily="Segoe UI" FontSize="14" TextDecorations="Underline"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="配置">
                            <syncfusion:RibbonButton Label="左揃え" SizeForm="Small" Click="ExcelAlignLeft_Click" ToolTip="左揃え">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8E4;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="中央揃え" SizeForm="Small" Click="ExcelAlignCenter_Click" ToolTip="中央揃え">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8E3;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="右揃え" SizeForm="Small" Click="ExcelAlignRight_Click" ToolTip="右揃え">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8E2;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="数値">
                            <syncfusion:RibbonButton Label="%" SizeForm="Small" Click="ExcelPercent_Click" ToolTip="パーセント表示">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="%" FontSize="14" FontWeight="Bold"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="桁区切り" SizeForm="Small" Click="ExcelComma_Click" ToolTip="桁区切りスタイル">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="," FontSize="14" FontWeight="Bold"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                    </syncfusion:RibbonTab>
                    <syncfusion:RibbonTab Caption="AI">
                        <syncfusion:RibbonBar Header="AI アシスタント">
                            <syncfusion:RibbonButton Label="AI チャット" SizeForm="Large" Click="ToggleChatPane_Click" ToolTip="AI コンシェルジュを開く">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="データ分析" SizeForm="Large" Click="AiAnalyze_Click" ToolTip="スプレッドシートのデータを AI で分析">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="数式ヘルプ" SizeForm="Large" Click="AiExcelFormula_Click" ToolTip="Excel 数式・関数を AI に相談">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="fx" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="横断分析" SizeForm="Large" Click="CrossFormatAnalysis_Click" ToolTip="ドキュメント＋参考資料を横断的に AI 分析">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="AI レポート" SizeForm="Large" Click="AiGenerateReport_Click" ToolTip="Excel データから Word レポートを AI 生成">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="プロンプト・資料">
                            <syncfusion:RibbonButton Label="プロンプト管理" SizeForm="Large" Click="TogglePromptPane_Click" ToolTip="プロンプトの作成・管理">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="参考資料" SizeForm="Large" Click="ToggleReferencePane_Click" ToolTip="参考資料パネルを開く">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="AI 設定">
                            <syncfusion:RibbonButton Label="AI 設定" SizeForm="Large" Click="AiSettings_Click" ToolTip="AI 設定">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                    </syncfusion:RibbonTab>
                </syncfusion:Ribbon.Items>
                <syncfusion:Ribbon.BackStage>
                    <syncfusion:Backstage Background="{StaticResource BgPrimaryBrush}">
                        <syncfusion:BackStageCommandButton Header="開く" Command="{Binding OpenDocumentCommand}">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageCommandButton Header="名前を付けて保存" Click="ExportExcel_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageSeparator/>
                        <syncfusion:BackStageCommandButton Header="ドキュメントを閉じる" Click="BackstageCloseDoc_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                    </syncfusion:Backstage>
                </syncfusion:Ribbon.BackStage>
            </syncfusion:Ribbon>
            </Border>

            <!-- ═══ PPTX Ribbon (Row 1) ═══ -->
            <Border x:Name="PptxRibbonPanel" Grid.Row="1" ClipToBounds="True" Visibility="Collapsed">
            <syncfusion:Ribbon x:Name="PptxRibbon"
                               ShowCustomizeRibbon="False"
                               EnableSimplifiedLayoutMode="False"
                               BackStageHeader="ファイル"
                               BackStageColor="{StaticResource PrimaryBrush}">
                <syncfusion:Ribbon.Items>
                    <syncfusion:RibbonTab Caption="ホーム" IsChecked="True">
                        <syncfusion:RibbonBar Header="ファイル">
                            <syncfusion:RibbonButton Label="開く" SizeForm="Small" Command="{Binding OpenDocumentCommand}" ToolTip="ファイルを開く">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="スライド情報">
                            <syncfusion:RibbonButton Label="テキスト抽出" SizeForm="Large" Click="PptxExtractText_Click" ToolTip="スライドのテキストを全文抽出">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                    </syncfusion:RibbonTab>
                    <syncfusion:RibbonTab Caption="AI">
                        <syncfusion:RibbonBar Header="AI アシスタント">
                            <syncfusion:RibbonButton Label="AI チャット" SizeForm="Large" Click="ToggleChatPane_Click" ToolTip="AI コンシェルジュ">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="要約" SizeForm="Large" Click="AiSummarize_Click" ToolTip="スライド内容を AI で要約">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="分析" SizeForm="Large" Click="AiAnalyze_Click" ToolTip="プレゼン構造を AI で分析">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="横断分析" SizeForm="Large" Click="CrossFormatAnalysis_Click" ToolTip="ドキュメント＋参考資料を横断的に AI 分析">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="プロンプト・資料">
                            <syncfusion:RibbonButton Label="プロンプト管理" SizeForm="Large" Click="TogglePromptPane_Click">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="参考資料" SizeForm="Large" Click="ToggleReferencePane_Click">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                        <syncfusion:RibbonBar Header="AI 設定">
                            <syncfusion:RibbonButton Label="AI 設定" SizeForm="Large" Click="AiSettings_Click">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                    </syncfusion:RibbonTab>
                </syncfusion:Ribbon.Items>
                <syncfusion:Ribbon.BackStage>
                    <syncfusion:Backstage Background="{StaticResource BgPrimaryBrush}">
                        <syncfusion:BackStageCommandButton Header="開く" Command="{Binding OpenDocumentCommand}">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageSeparator/>
                        <syncfusion:BackStageCommandButton Header="ドキュメントを閉じる" Click="BackstageCloseDoc_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                    </syncfusion:Backstage>
                </syncfusion:Ribbon.BackStage>
            </syncfusion:Ribbon>
            </Border>

            <!-- ═══ Main Content Area (Row 2) — 3-Pane Layout ═══ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftPanelCol" Width="0" MinWidth="0"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="RightPanelCol" Width="0" MinWidth="0"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ Left Panel: Reference Materials ═══ -->
                <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid Background="{StaticResource BgCardBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="12,8,8,4">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button x:Name="RefAddFolderBtn" Click="AddReferenceFolder_Click"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,2">
                                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="15"/>
                                    </Button>
                                    <Button x:Name="RefAddFileBtn" Click="AddReference_Click"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,2">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="15"/>
                                    </Button>
                                    <Button x:Name="RefCloseBtn" Click="CloseLeftPanel_Click"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,2" Margin="4,0,0,0">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                    </Button>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="RefHeaderText" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="RefCountText" Text="" FontSize="11" Margin="8,0,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Search/Filter -->
                        <Border Grid.Row="1" Background="{StaticResource BgSecondaryBrush}" Padding="12,0,12,6">
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3" Background="White">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="6,0,4,0"/>
                                    <TextBox x:Name="RefFilterBox" BorderThickness="0" FontSize="12" Padding="2,4"
                                             VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                        </Border>

                        <!-- Reference File List -->
                        <Grid Grid.Row="2">
                            <!-- Empty State / Drop Zone -->
                            <Border x:Name="RefDropZone" Padding="20"
                                    AllowDrop="True" Drop="OnReferenceDrop" DragOver="OnReferenceDragOver">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                            x:Name="RefEmptyState">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                               HorizontalAlignment="Center" Margin="0,0,0,8"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                    <TextBlock x:Name="RefEmptyHint" FontSize="12" TextAlignment="Center"
                                               Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="Word / Excel / PowerPoint / Text" FontSize="10" TextAlignment="Center"
                                               Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <ListBox x:Name="ReferenceList" BorderThickness="0"
                                     Background="Transparent" HorizontalContentAlignment="Stretch"
                                     Padding="4,2"
                                     AllowDrop="True" Drop="OnReferenceDrop" DragOver="OnReferenceDragOver"/>
                        </Grid>

                        <!-- Status -->
                        <Border Grid.Row="3" Background="{StaticResource BgSecondaryBrush}" Padding="8,4"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                            <TextBlock x:Name="RefStatusText" Text="" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Left Splitter -->
                <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"/>

                <!-- ═══ Center: Document Editor Area ═══ -->
                <Grid Grid.Column="2">
                    <!-- Welcome Panel (visible when no file is open) -->
                    <Border x:Name="WelcomePanel" Background="{StaticResource BgPrimaryBrush}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="480">
                            <TextBlock Text="Insight" FontSize="36" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="AI Office" FontSize="28" FontWeight="Light"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="WelcomeTagline" Text="Word・Excel・PowerPoint をAIと一緒に"
                                       FontSize="14" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,32"/>

                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="24,20"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock x:Name="WelcomeStartLabel" Text="はじめに"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                                    <Button Command="{Binding OpenDocumentCommand}" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Width="28"/>
                                            <StackPanel>
                                                <TextBlock x:Name="WelcomeOpenLabel" Text="ファイルを開く" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="WelcomeOpenDesc" Text=".docx / .xlsx / .pptx / .iaof"
                                                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>

                                    <Button Click="ToggleChatPane_Click" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Width="28"/>
                                            <StackPanel>
                                                <TextBlock x:Name="WelcomeChatLabel" Text="AI チャットを開く" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="WelcomeChatDesc" Text="ドキュメント生成・分析・質問応答" FontSize="11"
                                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>

                                    <Button Click="AiGenerateDoc_Click" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Width="28"/>
                                            <StackPanel>
                                                <TextBlock x:Name="WelcomeGenLabel" Text="AI 文書生成" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="WelcomeGenDesc" Text="プロンプトからドキュメントを自動作成" FontSize="11"
                                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="WelcomeDragHint" Text="ファイルをドラッグ＆ドロップでも開けます"
                                       FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Word Editor Panel -->
                    <Grid x:Name="WordEditorPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="12,4">
                            <Grid>
                                <TextBlock x:Name="WordFileName" Text="" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                        Click="CloseEditor_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <rte:SfRichTextBoxAdv x:Name="RichTextEditor" Grid.Row="1" IsReadOnly="False" Background="#F0F0F0"/>
                    </Grid>

                    <!-- Excel Editor Panel -->
                    <Grid x:Name="ExcelEditorPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="12,4">
                            <Grid>
                                <TextBlock x:Name="ExcelFileName" Text="" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                        Click="CloseEditor_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <syncfusion:SfSpreadsheet x:Name="Spreadsheet" Grid.Row="1"/>
                    </Grid>

                    <!-- PPTX Slide Viewer Panel -->
                    <Grid x:Name="PptxInfoPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Header bar -->
                        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="12,4">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="PptxFileName" Text="" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PptxSlideCount" Text="" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                        Click="CloseEditor_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <!-- Slide thumbnails (left) + Main slide view (center) -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Slide thumbnail list -->
                            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                                    Background="{StaticResource BgSecondaryBrush}">
                                <ListBox x:Name="PptxSlideList" SelectionChanged="PptxSlideList_SelectionChanged"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         HorizontalContentAlignment="Center" Padding="4">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2,4">
                                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        Background="White" HorizontalAlignment="Center">
                                                    <Image Source="{Binding Thumbnail}" Width="130" Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>
                                                <TextBlock Text="{Binding Label}" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            <!-- Main slide image -->
                            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto" Background="#F0F0F0">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                                    <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.2" Color="Black"/>
                                        </Border.Effect>
                                        <Image x:Name="PptxMainSlideImage" Stretch="Uniform"
                                               MaxWidth="900" MaxHeight="680"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Right Splitter -->
                <GridSplitter Grid.Column="3" Width="4" Background="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"/>

                <!-- ═══ Right Panel: AI Chat ═══ -->
                <views:ChatPanelView x:Name="ChatPanel" Grid.Column="4"/>
            </Grid>

            <!-- ═══ Status Bar (Row 3) ═══ -->
            <Border Grid.Row="3" Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText" Grid.Column="0" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FileTypeLabel" Grid.Column="1" FontSize="11" Margin="12,0"
                               Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionText" Grid.Column="2" FontSize="11" Margin="12,0"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" FontSize="11"
                               Text="{Binding Source={x:Static ui:InsightScaleManager.Instance}, Path=ScalePercent}"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
