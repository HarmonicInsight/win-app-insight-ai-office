<Window x:Class="InsightAiOffice.App.Views.PromptEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プロンプトエディター"
        Width="780" Height="560" MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BgPrimaryBrush}"
        FontFamily="Yu Gothic UI, Meiryo, Segoe UI">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" MinWidth="150" MaxWidth="400"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Prompt List -->
        <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Margin="0,0,4,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ヘッダー（ゴールド背景） -->
                <Border Grid.Row="0" Background="{StaticResource PrimaryLightBrush}" Padding="8,6"
                        CornerRadius="4,4,0,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock x:Name="PromptListLabel" Text="プロンプト一覧"
                                   FontWeight="SemiBold" FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <!-- 検索ボックス -->
                        <Grid Margin="0,5,0,0">
                            <TextBox x:Name="SearchBox"
                                     FontSize="11" Padding="22,4,6,4"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Background="White"
                                     TextChanged="SearchBox_TextChanged"
                                     ToolTip="プリセットを検索"/>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" IsHitTestVisible="False"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                            <TextBlock x:Name="SearchPlaceholder"
                                       Text="検索..." FontSize="11" IsHitTestVisible="False"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="22,0,0,0"
                                       Visibility="Visible"/>
                        </Grid>
                        <!-- ビュー切替（機能別 / 業務別） -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <RadioButton x:Name="ViewByFunction" Content="機能別"
                                         FontSize="10" IsChecked="True"
                                         Checked="ViewMode_Changed" Margin="0,0,8,0"
                                         Foreground="{StaticResource TextPrimaryBrush}"/>
                            <RadioButton x:Name="ViewByScene" Content="業務別"
                                         FontSize="10"
                                         Checked="ViewMode_Changed"
                                         Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ツリー -->
                <TreeView Grid.Row="1" x:Name="PromptTree"
                          SelectedItemChanged="PromptTree_SelectedItemChanged"
                          BorderThickness="0" Background="Transparent">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="2,1"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>

                <!-- アクションボタン -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="6,4">
                    <Button x:Name="AddButton" Click="Add_Click"
                            Padding="10,4" Margin="0,0,4,0" Cursor="Hand"
                            FontSize="12" FontWeight="Bold"
                            Background="{StaticResource PrimaryBrush}" Foreground="White"
                            BorderThickness="0" ToolTip="マイプロンプトに新規追加">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="13" FontWeight="Bold" Margin="0,0,4,0"/>
                            <TextBlock Text="追加" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <!-- 組織に追加ボタンは右側エディタパネルに移動 -->
                    <Button x:Name="DeleteButton" Click="Delete_Click"
                            Padding="10,4" Cursor="Hand"
                            FontSize="11"
                            Background="Transparent"
                            BorderBrush="{StaticResource ErrorBrush}" Foreground="{StaticResource ErrorBrush}"
                            BorderThickness="1" IsEnabled="False"
                            ToolTip="選択中のプロンプトを削除">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE107;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,3,0"/>
                            <TextBlock Text="削除" FontSize="10"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

        <!-- Right: Editor -->
        <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="12">
            <Grid x:Name="EditorPanel" IsEnabled="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <TextBlock Grid.Row="0" x:Name="NameLabel" Text="タイトル"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Row="1" x:Name="NameBox" FontSize="12" Padding="6,4" Margin="0,0,0,8"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}"/>

                <!-- Category -->
                <TextBlock Grid.Row="2" x:Name="CategoryLabel" Text="カテゴリ"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox Grid.Row="3" x:Name="CategoryCombo" IsEditable="True"
                          FontSize="12" Padding="6,4" Margin="0,0,0,8"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrush}"/>

                <!-- Prompt Label + Font Size -->
                <DockPanel Grid.Row="4" Margin="0,0,0,3">
                    <TextBlock x:Name="PromptTextLabel" Text="プロンプト"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="A&#x2212;" Click="FontSizeDown_Click" Padding="4,1" MinWidth="24" MinHeight="0"
                                FontSize="10" Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" Cursor="Hand" Margin="0,0,2,0" ToolTip="フォントサイズ縮小"/>
                        <TextBlock x:Name="FontSizeLabel" Text="13" FontSize="10" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" MinWidth="16" TextAlignment="Center"/>
                        <Button Content="A+" Click="FontSizeUp_Click" Padding="4,1" MinWidth="24" MinHeight="0"
                                FontSize="10" Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" Cursor="Hand" Margin="2,0,0,0" ToolTip="フォントサイズ拡大"/>
                    </StackPanel>
                </DockPanel>

                <!-- Prompt Text -->
                <TextBox Grid.Row="5" x:Name="PromptBox" FontSize="13" Padding="8,6"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}"/>

                <!-- Buttons -->
                <DockPanel Grid.Row="6" Margin="0,8,0,0">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button x:Name="ExportButton"
                                Click="Export_Click" Padding="10,6" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" FontSize="11"
                                Margin="0,0,4,0" ToolTip="組織プリセットをファイルに書き出し（他の端末に配布）">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="組織配布" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ImportButton"
                                Click="Import_Click" Padding="10,6" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" FontSize="11"
                                ToolTip="配布された組織プリセットを取り込み">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="取り込み" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="AddToOrgButton" Click="AddToOrg_Click"
                                Padding="12,6" Margin="0,0,6,0" Cursor="Hand"
                                FontSize="11" IsEnabled="False"
                                Background="#7C3AED" Foreground="White"
                                BorderThickness="0"
                                ToolTip="このプリセットを自組織プリセットに追加（チーム共有用）">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏢" FontSize="11" Margin="0,0,3,0"/>
                                <TextBlock Text="組織に追加" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="CustomizeButton"
                                Click="Customize_Click" Padding="16,6" Cursor="Hand"
                                Background="#7C3AED" Foreground="White"
                                BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                                Margin="0,0,6,0" IsEnabled="False"
                                ToolTip="プリセットを修正してマイプロンプトに登録"/>
                        <Button x:Name="SaveButton"
                                Click="Save_Click" Padding="16,6" Cursor="Hand"
                                Background="{StaticResource PrimaryBrush}" Foreground="White"
                                BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                                Margin="0,0,6,0" IsEnabled="False"/>
                        <Button x:Name="ExecuteButton"
                                Click="Execute_Click" Padding="16,6" Cursor="Hand"
                                Background="{StaticResource PrimaryBrush}" Foreground="White"
                                BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                                IsEnabled="False"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
