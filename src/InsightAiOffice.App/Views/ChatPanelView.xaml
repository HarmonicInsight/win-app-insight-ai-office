<UserControl x:Class="InsightAiOffice.App.Views.ChatPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:InsightAiOffice.App.Helpers">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BgCardBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>              <!-- 0: Header -->
            <RowDefinition Height="*" MinHeight="0"/>   <!-- 1: Preset Prompts (variable) -->
            <RowDefinition Height="Auto"/>              <!-- 2: GridSplitter -->
            <RowDefinition Height="2*"/>                <!-- 3: Chat Area -->
            <RowDefinition Height="Auto"/>              <!-- 4: Input Area -->
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryLightBrush}"
                Padding="10,7"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- Title + icon buttons -->
                <DockPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PanelTitle}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Click="Help_Click"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="3,1" Margin="6,0,0,0"
                                MinWidth="0" MinHeight="0">
                            <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                        </Button>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Command="{Binding OpenAiSettingsCommand}"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="4,2" FontSize="14">
                            <TextBlock Text="&#x2699;" FontSize="14"/>
                        </Button>
                        <Button Click="Close_Click"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" VerticalAlignment="Center" Padding="4" Margin="4,0,0,0">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
                <!-- Preset toggle + Prompt Editor button -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <ToggleButton IsChecked="{Binding IsPresetsExpanded}"
                                  Padding="8,3" MinWidth="0" MinHeight="0"
                                  Background="Transparent" BorderThickness="1"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  Cursor="Hand" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock x:Name="PresetToggleLabel" FontSize="10"/>
                        </StackPanel>
                    </ToggleButton>
                    <Button Click="PromptEditor_Click"
                            Background="White" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            HorizontalAlignment="Left"
                            Padding="8,3" Cursor="Hand"
                            MinWidth="0" MinHeight="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock x:Name="PromptEditorLabel" FontSize="10"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 1: Preset Prompts (collapsible) -->
        <Border Grid.Row="1"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding IsPresetsExpanded, Converter={StaticResource BoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="4,2">
                <ItemsControl ItemsSource="{Binding PresetPromptGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2">
                                <TextBlock Text="{Binding CategoryName}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="8,4,0,2"
                                           FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                                <ItemsControl ItemsSource="{Binding Prompts}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource BgSecondaryBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1" CornerRadius="10"
                                                    Padding="7,3" Margin="0,0,3,3" Cursor="Hand"
                                                    MouseLeftButtonDown="PresetChip_Click">
                                                <TextBlock Text="{Binding Label}" FontSize="10"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Row 2: GridSplitter -->
        <GridSplitter Grid.Row="2" Height="6"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="Transparent" Cursor="SizeNS"
                      Visibility="{Binding IsPresetsExpanded, Converter={StaticResource BoolToVis}}"/>

        <!-- Row 3: Chat Area -->
        <Grid Grid.Row="3">
            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="8,4">
                <ItemsControl ItemsSource="{Binding ChatMessages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4,3" Padding="10,7" MaxWidth="380"
                                    CornerRadius="12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}"/>
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Role}" Value="User">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="CornerRadius" Value="12,12,0,12"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                <Setter Property="Background" Value="#F3E5F5"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="CornerRadius" Value="12,12,12,0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Role}" Value="System">
                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBox Text="{Binding Content, Mode=OneWay}"
                                             TextWrapping="Wrap" FontSize="12.5"
                                             FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             Background="Transparent" BorderThickness="0"
                                             IsReadOnly="True" Cursor="Arrow"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                                Visibility="{Binding ActionVisibility}">
                                        <Button Content="{x:Static helpers:LanguageManager.InsertToDocLabel}"
                                                FontSize="11" Padding="8,3"
                                                Background="{StaticResource PrimaryBrush}" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="InsertAiResponse_Click"
                                                Tag="{Binding Content}"/>
                                        <Button Content="{x:Static helpers:LanguageManager.CopyLabel}"
                                                FontSize="11" Padding="8,3" Margin="4,0,0,0"
                                                Background="Transparent" BorderThickness="1"
                                                BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                                                Click="CopyAiResponse_Click"
                                                Tag="{Binding Content}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Row 4: Input Area -->
        <Border Grid.Row="4"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <StackPanel>
                <!-- Processing indicator -->
                <DockPanel Margin="0,0,0,4"
                           Visibility="{Binding IsSending, Converter={StaticResource BoolToVis}}">
                    <Button DockPanel.Dock="Right"
                            Command="{Binding CancelSendCommand}"
                            FontSize="10" Padding="6,2"
                            Background="Transparent" Foreground="{StaticResource ErrorBrush}"
                            BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1"
                            Cursor="Hand">
                        <TextBlock x:Name="CancelLabel"/>
                    </Button>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="●" FontSize="8"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding AiProcessingModelName}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AiProcessingText}"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontStyle="Italic" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>

                <!-- Input + Send + Clear -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ChatInput" Grid.Column="0"
                             Text="{Binding AiInput, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="90" MaxHeight="200"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="12" Padding="8,6"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             KeyDown="ChatInput_KeyDown"
                             AutomationProperties.Name="AI prompt input"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="4,0,0,0">
                        <Button Padding="8,6" MinWidth="36"
                                Background="{StaticResource PrimaryBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Command="{Binding ExecuteSelectedPromptCommand}">
                            <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </Button>
                        <Button Command="{Binding ClearChatCommand}"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="4,2" Margin="0,2,0,0">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
