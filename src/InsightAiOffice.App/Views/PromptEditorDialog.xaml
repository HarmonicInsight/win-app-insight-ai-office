<Window x:Class="InsightAiOffice.App.Views.PromptEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プロンプトエディター"
        Width="780" Height="560" MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BgPrimaryBrush}"
        FontFamily="Yu Gothic UI, Meiryo, Segoe UI">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" MinWidth="150" MaxWidth="400"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Prompt List -->
        <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Margin="0,0,4,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ヘッダー（ゴールド背景） -->
                <Border Grid.Row="0" Background="{StaticResource PrimaryLightBrush}" Padding="8,6"
                        CornerRadius="4,4,0,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock x:Name="PromptListLabel" Text="プロンプト一覧"
                               FontWeight="SemiBold" FontSize="12"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </Border>

                <!-- ツリー -->
                <TreeView Grid.Row="1" x:Name="PromptTree"
                          SelectedItemChanged="PromptTree_SelectedItemChanged"
                          BorderThickness="0" Background="Transparent">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="2,1"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>

                <!-- 追加・削除ボタン -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="4">
                    <Button x:Name="AddButton" Content="+" Click="Add_Click" Padding="8,2" Margin="0,0,4,0"
                            FontSize="14" FontWeight="Bold" Cursor="Hand"
                            Background="{StaticResource PrimaryBrush}" Foreground="White"
                            BorderThickness="0" ToolTip="プロンプト追加"/>
                    <Button x:Name="DeleteButton" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                            Click="Delete_Click" Padding="8,2" FontSize="12" Cursor="Hand"
                            Background="Transparent" BorderBrush="{StaticResource ErrorBrush}"
                            Foreground="{StaticResource ErrorBrush}"
                            BorderThickness="1" IsEnabled="False" ToolTip="削除"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

        <!-- Right: Editor -->
        <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="12">
            <Grid x:Name="EditorPanel" IsEnabled="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <TextBlock Grid.Row="0" x:Name="NameLabel" Text="タイトル"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Row="1" x:Name="NameBox" FontSize="12" Padding="6,4" Margin="0,0,0,8"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}"/>

                <!-- Category -->
                <TextBlock Grid.Row="2" x:Name="CategoryLabel" Text="カテゴリ"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox Grid.Row="3" x:Name="CategoryCombo" IsEditable="True"
                          FontSize="12" Padding="6,4" Margin="0,0,0,8"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrush}"/>

                <!-- Prompt Label + Font Size -->
                <DockPanel Grid.Row="4" Margin="0,0,0,3">
                    <TextBlock x:Name="PromptTextLabel" Text="プロンプト"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="A&#x2212;" Click="FontSizeDown_Click" Padding="4,1" MinWidth="24" MinHeight="0"
                                FontSize="10" Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" Cursor="Hand" Margin="0,0,2,0" ToolTip="フォントサイズ縮小"/>
                        <TextBlock x:Name="FontSizeLabel" Text="13" FontSize="10" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" MinWidth="16" TextAlignment="Center"/>
                        <Button Content="A+" Click="FontSizeUp_Click" Padding="4,1" MinWidth="24" MinHeight="0"
                                FontSize="10" Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" Cursor="Hand" Margin="2,0,0,0" ToolTip="フォントサイズ拡大"/>
                    </StackPanel>
                </DockPanel>

                <!-- Prompt Text -->
                <TextBox Grid.Row="5" x:Name="PromptBox" FontSize="13" Padding="8,6"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}"/>

                <!-- Buttons -->
                <DockPanel Grid.Row="6" Margin="0,8,0,0">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button x:Name="ExportButton"
                                Click="Export_Click" Padding="10,6" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" FontSize="11"
                                Margin="0,0,4,0" ToolTip="プロンプトをエクスポート">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="Export" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ImportButton"
                                Click="Import_Click" Padding="10,6" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" FontSize="11"
                                ToolTip="プロンプトをインポート">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="Import" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CustomizeButton"
                                Click="Customize_Click" Padding="16,6" Cursor="Hand"
                                Background="#7C3AED" Foreground="White"
                                BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                                Margin="0,0,6,0" IsEnabled="False"
                                ToolTip="プリセットを修正してマイプロンプトに登録"/>
                        <Button x:Name="SaveButton"
                                Click="Save_Click" Padding="16,6" Cursor="Hand"
                                Background="{StaticResource PrimaryBrush}" Foreground="White"
                                BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                                Margin="0,0,6,0" IsEnabled="False"/>
                        <Button x:Name="ExecuteButton"
                                Click="Execute_Click" Padding="16,6" Cursor="Hand"
                                Background="{StaticResource PrimaryBrush}" Foreground="White"
                                BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                                IsEnabled="False"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
