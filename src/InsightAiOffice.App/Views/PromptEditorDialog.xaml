<Window x:Class="InsightAiOffice.App.Views.PromptEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompt Editor"
        Width="780" Height="520" MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimaryBrush}"
        FontFamily="Yu Gothic UI, Meiryo, Segoe UI">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="150"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Prompt Tree -->
        <DockPanel Grid.Column="0">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock x:Name="PromptListLabel" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                <Button x:Name="AddButton" Click="Add_Click"
                        HorizontalAlignment="Right" Padding="6,2" Cursor="Hand"
                        Background="Transparent" BorderThickness="1"
                        BorderBrush="{StaticResource BorderBrush}"
                        FontFamily="Yu Gothic UI, Meiryo, Segoe UI">
                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                </Button>
            </DockPanel>
            <TreeView x:Name="PromptTree"
                      SelectedItemChanged="PromptTree_SelectedItemChanged"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      Background="{StaticResource BgCardBrush}"
                      FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                      FontSize="11"/>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="6" Background="Transparent"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <!-- Right: Editor -->
        <Grid Grid.Column="2" x:Name="EditorPanel" IsEnabled="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0: Header -->
                <RowDefinition Height="Auto"/>  <!-- 1: Name -->
                <RowDefinition Height="Auto"/>  <!-- 2: Category -->
                <RowDefinition Height="Auto"/>  <!-- 3: Model -->
                <RowDefinition Height="Auto"/>  <!-- 4: Prompt label + font -->
                <RowDefinition Height="*"/>     <!-- 5: Prompt text -->
                <RowDefinition Height="Auto"/>  <!-- 6: Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryLightBrush}"
                    Padding="10,6" Margin="-1,-1,-1,8" CornerRadius="4,4,0,0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock x:Name="EditorTitle" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
            </Border>

            <!-- Name -->
            <StackPanel Grid.Row="1" Margin="0,0,0,6">
                <TextBlock x:Name="NameLabel" FontSize="11" Margin="0,0,0,3"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                <TextBox x:Name="NameBox" FontSize="12" Padding="6,4"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
            </StackPanel>

            <!-- Category -->
            <StackPanel Grid.Row="2" Margin="0,0,0,6">
                <TextBlock x:Name="CategoryLabel" FontSize="11" Margin="0,0,0,3"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                <ComboBox x:Name="CategoryCombo" IsEditable="True" FontSize="12" Padding="6,4"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
            </StackPanel>

            <!-- Model -->
            <StackPanel Grid.Row="3" Margin="0,0,0,6">
                <TextBlock x:Name="ModelLabel" FontSize="11" Margin="0,0,0,3"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                <ComboBox x:Name="ModelCombo" FontSize="12" Padding="6,4"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
            </StackPanel>

            <!-- Prompt Label + Font Size -->
            <DockPanel Grid.Row="4" Margin="0,0,0,3">
                <TextBlock x:Name="PromptTextLabel" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="A&#x2212;" Click="FontSizeDown_Click" FontSize="10" Padding="4,1"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                            FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                    <TextBlock x:Name="FontSizeLabel" Text="13" FontSize="10" Margin="4,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                    <Button Content="A+" Click="FontSizeUp_Click" FontSize="10" Padding="4,1"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                            FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                </StackPanel>
            </DockPanel>

            <!-- Prompt Text -->
            <TextBox Grid.Row="5" x:Name="PromptBox"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="13" Padding="8,6"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>

            <!-- Buttons -->
            <DockPanel Grid.Row="6" Margin="0,8,0,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button x:Name="ExportButton"
                            Click="Export_Click" Padding="10,6" Cursor="Hand"
                            Background="Transparent"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" FontSize="11"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Text="Export" FontFamily="Yu Gothic UI, Meiryo, Segoe UI" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ImportButton"
                            Click="Import_Click" Padding="10,6" Cursor="Hand"
                            Background="Transparent"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" FontSize="11">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Text="Import" FontFamily="Yu Gothic UI, Meiryo, Segoe UI" FontSize="11"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CustomizeButton"
                            Click="Customize_Click" Padding="16,6" Margin="0,0,6,0" Cursor="Hand"
                            Background="#7C3AED" Foreground="White"
                            BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                            IsEnabled="False"
                            FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                    <Button x:Name="SaveButton"
                            Click="Save_Click" Padding="16,6" Margin="0,0,6,0" Cursor="Hand"
                            Background="{StaticResource PrimaryBrush}" Foreground="White"
                            BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                            IsEnabled="False"
                            FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                    <Button x:Name="ExecuteButton"
                            Click="Execute_Click" Padding="16,6" Cursor="Hand"
                            Background="{StaticResource PrimaryBrush}" Foreground="White"
                            BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                            IsEnabled="False"
                            FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                    <Button x:Name="DeleteButton"
                            Click="Delete_Click" Padding="10,6" Margin="6,0,0,0" Cursor="Hand"
                            Background="Transparent"
                            Foreground="{StaticResource ErrorBrush}"
                            BorderBrush="{StaticResource ErrorBrush}"
                            BorderThickness="1" FontSize="11"
                            IsEnabled="False"
                            FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
