                        <syncfusion:RibbonBar Header="ヘルプ">
                            <syncfusion:RibbonButton Label="チュートリアル" SizeForm="Small" Click="Tutorial_Click" ToolTip="サンプルデータで機能を体験">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBrush}"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                            <syncfusion:RibbonButton Label="ヘルプ" SizeForm="Small" Click="RibbonHelp_Click" ToolTip="ヘルプ (F1)">
                                <syncfusion:RibbonButton.IconTemplate><DataTemplate><TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="14"/></DataTemplate></syncfusion:RibbonButton.IconTemplate>
                            </syncfusion:RibbonButton>
                        </syncfusion:RibbonBar>
                    </syncfusion:RibbonTab>
                </syncfusion:Ribbon.Items>
                <syncfusion:Ribbon.BackStage>
                    <syncfusion:Backstage Background="{StaticResource BgPrimaryBrush}">
                        <syncfusion:BackStageCommandButton Header="開く" Click="BackstageOpen_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageCommandButton Header="保存" Click="TextSave_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                        <syncfusion:BackStageCommandButton Header="ドキュメントを閉じる" Click="BackstageCloseDoc_Click">
                            <syncfusion:BackStageCommandButton.IconTemplate><DataTemplate><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate></syncfusion:BackStageCommandButton.IconTemplate>
                        </syncfusion:BackStageCommandButton>
                    </syncfusion:Backstage>
                </syncfusion:Ribbon.BackStage>
            </syncfusion:Ribbon>
            </Border>

            <!-- ═══ Main Content Area (Row 2) — 2-Pane Layout ═══ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>     <!-- center -->
                    <ColumnDefinition Width="Auto"/>  <!-- right splitter -->
                    <ColumnDefinition x:Name="RightPanelCol" Width="0" MinWidth="0"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ Center: Document Editor Area ═══ -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Document Tab Bar -->
                    <Border x:Name="TabBarPanel" Grid.Row="0" Visibility="Collapsed"
                            Background="{StaticResource BgSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                      VerticalAlignment="Bottom">
                            <StackPanel x:Name="TabBarItems" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Editor Panels Container -->
                    <Grid Grid.Row="1">
                    <!-- Welcome Panel (visible when no file is open) -->
                    <Border x:Name="WelcomePanel" Background="{StaticResource BgPrimaryBrush}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="680">
                            <TextBlock Text="Insight" FontSize="36" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="AI Office" FontSize="28" FontWeight="Light"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="WelcomeTagline" Text="AI の民主化：誰もが業務で AI を使えるように"
                                       FontSize="14" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,28"/>

                            <!-- 4 Action Cards -->
                            <UniformGrid Columns="4" Margin="0,0,0,20">
                                <!-- Card 1: プロジェクトを開く -->
                                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14,12"
                                        BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1.5" Margin="0,0,4,0"
                                        Cursor="Hand" MouseLeftButtonUp="WelcomeOpenProject_Click">
                                    <StackPanel>
                                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                   Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="プロジェクトを開く"
                                                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,3"/>
                                        <TextBlock Text=".iaof を開いて&#x0a;AI履歴ごと復元"
                                                   FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <!-- Card 2: ファイルを開く -->
                                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14,12"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="4,0,4,0"
                                        Cursor="Hand" MouseLeftButtonUp="WelcomeOpen_Click">
                                    <StackPanel>
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                   Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock x:Name="WelcomeOpenLabel" Text="ファイルを開く"
                                                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,3"/>
                                        <TextBlock x:Name="WelcomeOpenDesc"
                                                   Text=".docx / .xlsx / .txt&#x0a;.pptx / .pdf"
                                                   FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <!-- Card 3: AIコンシェルジュ -->
                                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14,12"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="4,0,4,0"
                                        Cursor="Hand" MouseLeftButtonUp="WelcomeChat_Click">
                                    <StackPanel>
                                        <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                   Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock x:Name="WelcomeChatLabel" Text="AI コンシェルジュ"
                                                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,3"/>
                                        <TextBlock x:Name="WelcomeChatDesc"
                                                   Text="翻訳・分析・要約&#x0a;レポート自動生成"
                                                   FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <!-- Card 4: チュートリアル -->
                                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14,12"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="4,0,0,0"
                                        Cursor="Hand" MouseLeftButtonUp="WelcomeTutorial_Click">
                                    <StackPanel>
                                        <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                   Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="チュートリアル"
                                                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,3"/>
                                        <TextBlock Text="サンプルデータで&#x0a;ワンクリック体験"
                                                   FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- 最近使ったファイル -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock x:Name="WelcomeRecentTitle" Text="最近使ったファイル" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                                <ItemsControl x:Name="WelcomeRecentList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="6" Padding="10,7" Margin="0,0,8,8"
                                                    Cursor="Hand" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                    MouseLeftButtonUp="WelcomeRecentFile_Click" Tag="{Binding FilePath}"
                                                    ToolTip="{Binding FilePath}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding FileName}" FontSize="12"
                                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="WelcomeRecentEmpty" Text="まだファイルを開いていません"
                                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,4,0,0" Visibility="Collapsed"/>
                            </StackPanel>

                            <TextBlock x:Name="WelcomeDragHint" Text="ファイルをドラッグ＆ドロップでも開けます"
                                       FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Word Editor Panel -->
                    <Grid x:Name="WordEditorPanel" Visibility="Collapsed">
                        <rte:SfRichTextBoxAdv x:Name="RichTextEditor" IsReadOnly="False" Background="#F0F0F0"/>
                    </Grid>

                    <!-- Excel Editor Panel -->
                    <Grid x:Name="ExcelEditorPanel" Visibility="Collapsed">
                        <syncfusion:SfSpreadsheet x:Name="Spreadsheet"/>
                    </Grid>

                    <!-- Text Editor Panel -->
                    <Grid x:Name="TextEditorPanel" Visibility="Collapsed">
                        <TextBox x:Name="TextEditor"
                                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Yu Gothic UI, Meiryo"
                                 FontSize="13" Padding="12,8"
                                 Background="White" Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderThickness="0"
                                 AutomationProperties.Name="Text editor"/>
                    </Grid>

                    <!-- PPTX Slide Viewer Panel -->
                    <Grid x:Name="PptxInfoPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Header bar -->
                        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="12,4">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="参照モード" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                    <TextBlock x:Name="PptxFileName" Text="" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PptxSlideCount" Text="" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                        Click="CloseEditor_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <!-- Slide thumbnails (left) + Main slide view (center) -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Slide thumbnail list -->
                            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                                    Background="{StaticResource BgSecondaryBrush}">
                                <ListBox x:Name="PptxSlideList" SelectionChanged="PptxSlideList_SelectionChanged"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         HorizontalContentAlignment="Center" Padding="4">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2,4">
                                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        Background="White" HorizontalAlignment="Center">
                                                    <Image Source="{Binding Thumbnail}" Width="130" Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>
                                                <TextBlock Text="{Binding Label}" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            <!-- Main slide image -->
                            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto" Background="#F0F0F0">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                                    <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.2" Color="Black"/>
                                        </Border.Effect>
                                        <Image x:Name="PptxMainSlideImage" Stretch="Uniform"
                                               MaxWidth="900" MaxHeight="680"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- PDF Viewer Panel -->
                    <Grid x:Name="PdfViewerPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="12,4">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="参照モード" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                    <TextBlock x:Name="PdfFileName" Text="" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                        Click="CloseEditor_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <pdfviewer:PdfViewerControl x:Name="PdfViewer" Grid.Row="1"
                                                       IsBookmarkEnabled="True"/>
                    </Grid>

                    </Grid> <!-- End Editor Panels Container -->
                </Grid>

                <!-- Right Splitter -->
                <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"/>

                <!-- ═══ Right Panel: AI Chat ═══ -->
                <views:ChatPanelView x:Name="ChatPanel" Grid.Column="2"/>
            </Grid>

            <!-- ═══ Status Bar (Row 3) ═══ -->
            <Border Grid.Row="3" Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText" Grid.Column="0" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FileTypeLabel" Grid.Column="1" FontSize="11" Margin="12,0"
                               Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionText" Grid.Column="2" FontSize="11" Margin="12,0"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Click="ScaleDown_Click" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="4,0" MinWidth="0" MinHeight="0" ToolTip="縮小 (Ctrl+-)">
                            <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                        <TextBlock FontSize="11" Margin="4,0"
                                   Text="{Binding Source={x:Static ui:InsightScaleManager.Instance}, Path=ScalePercent}"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <Button Click="ScaleUp_Click" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="4,0" MinWidth="0" MinHeight="0" ToolTip="拡大 (Ctrl++)">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
